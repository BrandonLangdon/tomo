{
  "name": "Tomo",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron electron/main.cjs",
    "app": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron electron/main.cjs\"",
    "pack": "vite build && electron-builder --dir",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.tomo.alpha",
    "productName": "Tomo",
    "asar": true,
    "directories": { "output": "../../build/dist-app" },
    "files": ["electron/**/*", "dist/**/*", "package.json"],
    "extraResources": [
      { "from": "../../build/python", "to": "python" },
      { "from": "../Python_Backend", "to": "backend", "filter": ["**/*", "!logs/**", "!**/__pycache__/**"] }
    ],
    "win": { "target": "nsis", "icon": "build/icon.ico" },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.graphics-design",
      "identity": null,
      "artifactName": "Tomo-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "warningsAsErrors": false
    }
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.4",
    "wait-on": "^9.0.10"
  }
}
